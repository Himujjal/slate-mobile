{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "types": ["bun-types"],
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@ui/*": ["../ui/*"],
      "@app/*": ["../app/*"],
      "@hooks/*": ["../hooks/*"],
      "@constants/*": ["../constants/*"],
      "@flux/*": ["../flux/*"],
      "@scripts/*": ["../scripts/*"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}
