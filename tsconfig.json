{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@ui/*": ["./ui/*"],
      "@app/*": ["./app/*"],
      "@hooks/*": ["./hooks/*"],
      "@constants/*": ["./constants/*"],
      "@flux": ["./flux/index"],
      "@flux/*": ["./flux/*"],
      "@scripts/*": ["./scripts/*"],
      "@storage": ["./storage/index"],
      "@storage/*": ["./storage/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
