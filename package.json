{
  "name": "slate",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:expo\"",
    "dev:server": "bun run --watch server/index.ts",
    "dev:expo": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "commitcheck": "npx commitlint --from HEAD~1 --to HEAD --verbose",
    "postinstall": "node scripts/install-githooks.js",
    "check-all": "concurrently \"npm run typecheck\" \"npm run lint\" \"npm run format\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@legendapp/state": "^3.0.0-beta.46",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.11",
    "@sinclair/typebox": "^0.34.49",
    "elysia": "^1.4.28",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "kysely": "^0.28.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.13",
    "@types/react": "~19.1.0",
    "concurrently": "^9.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
